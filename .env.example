```env
# ============================================================
# Mandate environment configuration
# ============================================================
# Current Sui network.
# Supported values: testnet | mainnet
#
# This single value drives:
# - RPC endpoint
# - Mandate package id
# - DeepBook route / pool
# - token config
# - explorer links
# - UI network labels
#
# Local development usually uses: testnet
# Production can use: testnet or mainnet
NEXT_PUBLIC_SUI_NETWORK=testnet


# ============================================================
# Testnet config
# ============================================================

# Optional custom Sui RPC endpoint for testnet.
# Leave empty to use the app default testnet RPC.
NEXT_PUBLIC_SUI_RPC_TESTNET=

# Mandate Move package id deployed on Sui testnet.
# Required for creating / revoking / withdrawing / executing mandates.
NEXT_PUBLIC_PACKAGE_ID_TESTNET=

# Current executable DeepBook route on testnet.
# For the demo, this is DEEP_SUI.
NEXT_PUBLIC_DEEPBOOK_POOL_KEY_TESTNET=DEEP_SUI

# DeepBook pool object id for the testnet route above.
# Required for real DeepBook execution.
NEXT_PUBLIC_DEEPBOOK_POOL_ID_TESTNET=

# Coin type spent from the Mandate vault.
# Current executable demo uses SUI vault.
NEXT_PUBLIC_SPEND_COIN_TYPE_TESTNET=0x2::sui::SUI

# Coin type bought by the Trading Agent.
# For DEEP_SUI, this should be the testnet DEEP coin type used by the configured DeepBook pool.
NEXT_PUBLIC_BUY_COIN_TYPE_TESTNET=

# Explorer base URL used by transaction / object links.
NEXT_PUBLIC_EXPLORER_BASE_URL_TESTNET=https://testnet.suivision.xyz


# ============================================================
# Mainnet config
# ============================================================
# Mainnet must be configured explicitly.
# Do not reuse testnet package ids, pool ids, or token types.

# Optional custom Sui RPC endpoint for mainnet.
# Leave empty to use the app default mainnet RPC.
NEXT_PUBLIC_SUI_RPC_MAINNET=

# Mandate Move package id deployed on Sui mainnet.
NEXT_PUBLIC_PACKAGE_ID_MAINNET=

# DeepBook route key for mainnet.
# Example: DEEP_SUI, SUI_USDC, or another route supported by the app config.
NEXT_PUBLIC_DEEPBOOK_POOL_KEY_MAINNET=

# DeepBook pool object id for the selected mainnet route.
NEXT_PUBLIC_DEEPBOOK_POOL_ID_MAINNET=

# Coin type spent from the Mandate vault on mainnet.
NEXT_PUBLIC_SPEND_COIN_TYPE_MAINNET=0x2::sui::SUI

# Coin type bought by the Trading Agent on mainnet.
NEXT_PUBLIC_BUY_COIN_TYPE_MAINNET=

# Explorer base URL used by transaction / object links.
NEXT_PUBLIC_EXPLORER_BASE_URL_MAINNET=https://suivision.xyz


# ============================================================
# Platform backend Agent signer
# ============================================================
# BACKEND_AGENT_PRIVATE_KEY is the platform backend Agent signer.
#
# It pays gas and submits autonomous PTBs.
# It is NOT the user's wallet private key.
#
# User assets come from the Mandate vault.
# Swap output assets return to the Owner wallet.
#
# Important:
# - This must NOT be prefixed with NEXT_PUBLIC.
# - Keep it server-side only.
# - If you switch to mainnet, use a dedicated mainnet Agent wallet.
BACKEND_AGENT_PRIVATE_KEY=

# Public address derived from BACKEND_AGENT_PRIVATE_KEY.
# This is shown in the UI and used when creating Mandates.
# The Mandate must authorize this exact Agent address.
NEXT_PUBLIC_BACKEND_AGENT_ADDRESS=


# ============================================================
# Optional generic AssetMandate<T> framework config
# ============================================================
# The generic AssetMandate<T> framework exists, but the current executable
# demo route is SUI vault -> DEEP through DEEP_SUI.
#
# DUSDC / Circle USDC were investigated on testnet, but no registered
# fillable DeepBook pool was found for those exact coin types.
#
# Do not enable these routes unless:
# - the coin type exactly matches a registered DeepBook pool
# - quote simulation confirms fillability
# - the frontend route is intentionally enabled
NEXT_PUBLIC_DEEPBOOK_POOL_KEY_SUI_DBUSDC=
NEXT_PUBLIC_DEEPBOOK_POOL_ID_SUI_DBUSDC=
NEXT_PUBLIC_DBUSDC_COIN_TYPE=


# ============================================================
# Optional local script testing
# ============================================================
# Fixed Mandate object id for local script testing only.
# The web app normally discovers Mandates from the connected Owner wallet.
MANDATE_ID=
```
