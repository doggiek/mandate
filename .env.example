# Current Sui network.
NEXT_PUBLIC_SUI_NETWORK=testnet

# Current published Move package.
# Must point to the latest vault-enabled mandate package.
PACKAGE_ID=
NEXT_PUBLIC_PACKAGE_ID=

# Platform backend Agent signer.
# The private key is server-only and pays gas for autonomous PTBs.
# This is NOT the user's wallet private key.
# 是平台后端 Agent signer，只用于支付 gas 和提交 autonomous PTB，不是用户钱包私钥。
BACKEND_AGENT_PRIVATE_KEY=

# Public address derived from BACKEND_AGENT_PRIVATE_KEY.
# Owner-created Mandates authorize this backend Agent address.
# 是由 BACKEND_AGENT_PRIVATE_KEY 推导出的 public address，Create Mandate 会授权这个地址
NEXT_PUBLIC_BACKEND_AGENT_ADDRESS=

# DeepBook route config lives in backend/frontend env, not in Move.
# Move only authorizes spending from the Mandate vault coin type.
#
# DEEP_SUI route: SUI vault -> buy DEEP.
# This is the current executable demo route.
# Some testnet pools may return NO_FILL for small orders due to limited liquidity.
# Use scripts/find-fillable-deepbook-pool.ts to discover a fillable pool before testing.
# For DEEP_SUI on current testnet, orders below ~1 SUI may return no fill.
NEXT_PUBLIC_DEEPBOOK_POOL_KEY_DEEP_SUI=DEEP_SUI
NEXT_PUBLIC_DEEPBOOK_POOL_ID_DEEP_SUI=

# SUI_DBUSDC route alias: DUSDC / USDC vault -> buy SUI.
# Generic AssetMandate<T> vault support is wired, but this route is disabled
# in the UI unless the coin type exactly matches a registered DeepBook pool.
# On current DeepBook testnet, wallet-held DUSDC and Circle testnet USDC have
# no registered fillable DeepBook pool. Do not enable SUI_DUSDC until discovery
# confirms the exact coin type, pool id, and quote fillability.
NEXT_PUBLIC_DEEPBOOK_POOL_KEY_SUI_DBUSDC=
NEXT_PUBLIC_DEEPBOOK_POOL_ID_SUI_DBUSDC=
NEXT_PUBLIC_DBUSDC_COIN_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# Legacy aliases kept for existing scripts/config.
NEXT_PUBLIC_DEEPBOOK_POOL_KEY=DEEP_SUI
NEXT_PUBLIC_DEEPBOOK_POOL_ID=

# Optional: fixed Mandate object for local script testing only.
# The web app should discover Mandates from the connected Owner wallet.
# Leave empty for normal app usage.
# 可选：只适合脚本调试，比如临时跑某个固定 mandate
MANDATE_ID=
